# Local Docker Postgres (default)
# DATABASE_URL=postgresql://queensbanquet:queensbanquet@localhost:5432/queensbanquet

# Supabase Postgres — paste URI from Project Settings → Database → Connection string (URI)
# Use Session mode (port 5432). Replace [YOUR-PASSWORD] with your database password.
# Example (pooler):
# DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# Example (direct):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://queensbanquet:queensbanquet@localhost:5432/queensbanquet

# Force TLS for cloud Postgres (auto-enabled when DATABASE_URL hosts supabase.co / supabase.com)
# DATABASE_SSL=true

PORT=4000
# Local: Vite origin. Production API: your Vercel URL(s), comma-separated if needed.
CORS_ORIGIN=http://localhost:5174
ADMIN_JWT_SECRET=change-me-in-production

# Used by npm run db:seed and offline admin fallback
ADMIN_EMAIL=queensbanquet07@gmail.com
ADMIN_PASSWORD=marou-admin
ADMIN_NAME=Marou Madrid

# Frontend → Express API (required for live Supabase-backed data)
# Local: http://localhost:4000
# Production (set in Vercel dashboard, then redeploy): https://your-api.onrender.com
VITE_API_BASE_URL=http://localhost:4000

# Optional frontend offline admin credentials (used only when API is unavailable)
# VITE_ADMIN_EMAIL=queensbanquet07@gmail.com
# VITE_ADMIN_PASSWORD=marou-admin
